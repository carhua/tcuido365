{% extends 'base.html.twig' %}
{% import 'macro/breadcrumb.html.twig' as breadcrumb %}
{% import 'macro/action.html.twig' as action %}
{% import 'macro/pagination.html.twig' as pagination %}

{% set _title = 'Historial - Casos Personas Desaparecidas' %}
{% set _main_title = 'Listado' %}
{% set _section =  'historial_desaparecido_index'%}

{% block _breadcrumb %}
    {{ breadcrumb.show('Historial - Casos Personas Desaparecidas') }}
{% endblock %}

{% block _main %}


            <form class="form" id="frm_filters">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="filter_text">Nombres</label>
                            <input type="text" class="form-control" placeholder="Buscar..." id="filter_text"
                                   value="{{app.request.get('b')}}" name="b" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="select_provincias">Provincia</label>
                            <select name="provincia" id="select_provincias" class="form-control m-select2">
                                <option value="" selected>Seleccione</option>
                                {% for provincia in provincias  %}
                                    <option value="{{ provincia.id }}" {{ provincia.id == provinciaId ? "selected":"" }}>
                                        {{ provincia.nombre }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="select_distritos">Distrito</label>
                            <select name="distrito" id="select_distritos" class="form-control m-select2">
                                <option value="">Seleccione</option>
                                {% for distrito in distritos %}
                                    <option value="{{ distrito.id }}">{{ distrito.nombre }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="select_centros">Centro Poblado</label>
                            <select name="centroPoblado" id="select_centros" class="form-control m-select2">
                                <option value="">Seleccione</option>
                                {% for centro in centrosPoblados %}
                                    <option value="{{ centro.id }}">{{ centro.nombre }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-md-12">
                        <button type="button" class="btn-send btn btn-primary">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                        <button type="button" onclick="actionForm('frm_filters')" class="btn-excel btn btn-success ml-2">
                            <i class="fas fa-file-excel"></i> Exportar
                        </button>
                    </div>
                </div>
            </form>
<br />
            <div id="table-container">
                <div class="table-responsive">
                    {{ action.tbl_start('table-sm table-bordered') }}
            <thead class="table-primary">
            <tr>
                <th class="text-center pb-10" rowspan="2">Nº</th>
                <th class="text-center d-sm-table-cell pb-10" rowspan="2">Distrito.</th>
                <th class="text-center d-sm-table-cell pb-10" rowspan="2">Centro Poblado.</th>
                <th class="text-center d-sm-table-cell pb-10" rowspan="2">Nombres</th>
                <th class="text-center d-sm-table-cell pb-10" rowspan="2">Edad</th>
                <th class="text-center d-sm-table-cell pb-10" rowspan="2">Sexo</th>
                <th class="text-center d-sm-table-cell " colspan="2">Casos de Personas Desaparecidas</th>
                <th class="text-center d-sm-table-cell pb-10" rowspan="2">Total</th>
            </tr>
            <tr>
                <th>Denunciante</th>
                <th>Desaparecido(a)</th>
            </tr>
            </thead>
            <tbody class="font-weight-bold">
            {% for den in paginator %}
                <tr>
                    <td class=" d-sm-table-cell">{{ loop.index}}</td>
                    <td class=" d-sm-table-cell">{{ den.centroPoblado.distrito.nombre}}</td>
                    <td class=" d-sm-table-cell">{{ den.centroPoblado.nombre |upper}}</td>
                    <td class=" d-sm-table-cell">{{ den.nombres |upper }}</td>
                    <td class=" d-sm-table-cell">{{ den.edad }} años</td>
                    <td class=" d-sm-table-cell">{{ den.sexo |upper }}</td>
                    <td class=" d-sm-table-cell {{ den.denuncianteDesaparecidos |length |semaforo }}">
                        {{ den.denuncianteDesaparecidos |length }}
                        {{ action.btn_show_link2_ico(path('historial_denunciantedes_index',{'numeroDocumento': den.numeroDocumento})) }}
                    </td>
                    <td class="d-none d-sm-table-cell {{ den.desaparecidos |length |semaforo }} ">
                        {{ den.desaparecidos |length }}
                        {{ action.btn_show_link2_ico(path('historial_desaparecidos_index',{'numeroDocumento': den.numeroDocumento})) }}
                    </td>
                    <td class="d-none d-sm-table-cell">
                        {% set c1 = den.denuncianteDesaparecidos |length  %}
                        {% set c2 = den.desaparecidos |length  %}
                        {% set total = c1+c2%}
                        {{ total}}
                        {{ action.btn_show_link2_ico(path('historial_totaldesaparecido_index',{'numeroDocumento': den.numeroDocumento,'personaid':den.id})) }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">No hay registros</td>
                </tr>
            {% endfor %}
            </tbody>
                    {{ action.tbl_end() }}
                </div>
                {{ pagination.pager(paginator, _section) }}
            </div>


{% endblock %}

{% block _main_filters %}
{% endblock %}

{% block _main_tools %}
{% endblock %}

{% block _main_footer %}
{% endblock%}

{% block _main_actions %}
{% endblock %}

{% block _stylesheets %}
{% endblock %}

{% block _javascripts %}
    <script>
        let route;
        function filter(routeBase)
        {
            route = routeBase + "?" + 'n=' + $('#filter_size option:selected').val();
            route = route + "&" + 'b=' + $('#filter_text').val();
            route = route + "&" + 'centroPoblado=' + "{{app.request.get('centroPoblado')}}";


            return route;
        }

        $(document).ready(function() {
            // Inicializar Select2 con allowClear
            $('.m-select2').select2({
                placeholder: "Seleccione",
                allowClear: true
            });

            $(document).on('change', '#filter_size', function(){
                route = '{{ path('historial_desaparecido_index') }}';
                window.location = filter(route);
            });

            $(document).on('click', '.btn-send', function(e){
                e.preventDefault();
                
                // Obtener los datos del formulario
                const formData = $('#frm_filters').serialize();
                
                // Mostrar indicador de carga
                $('.btn-send').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Cargando...');
                
                // Realizar petición AJAX
                $.ajax({
                    type: 'GET',
                    url: '{{ path('historial_desaparecido_index') }}',
                    data: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    success: function(response) {
                        // Actualizar la tabla con los nuevos resultados
                        $('#table-container').html(response);
                    },
                    error: function(xhr, status, error) {
                        console.error('Error al cargar los datos:', error);
                        alert('Error al cargar los datos del historial');
                    },
                    complete: function() {
                        // Restaurar botón
                        $('.btn-send').prop('disabled', false).html('<i class="fas fa-search"></i> Buscar');
                    }
                });
            });

            $(document).on('click', '.btn-clear', function(){
                route = '{{ path('historial_desaparecido_index') }}';
                window.location.href = route;
            });

            $("#select_provincias").change(function () {
                const provinciaId = $(this).val();
                const $distritos = $('#select_distritos');
                const $centros = $('#select_centros');
                
                // Limpiar distritos y centros poblados
                $distritos.html('<option value="">Seleccione</option>').val('').trigger('change');
                $centros.html('<option value="">Seleccione</option>').val('').trigger('change');
                
                // Si se seleccionó una provincia, cargar sus distritos
                if (provinciaId) {
                    $.ajax({
                        type: 'GET',
                        url: "{{ path('ubigeo_distritos_ajax', {'provinciaId': 'ID'}) }}".replace('ID', provinciaId),
                        success: function (data) {
                            for (let i = 0, total = data.length; i < total; i++) {
                                $distritos.append('<option value="' + data[i].id + '">' + data[i].name + '</option>');
                            }
                        }
                    });
                }
            });

            $("#select_distritos").change(function () {
                const distritoId = $(this).val();
                const $centros = $('#select_centros');
                
                // Limpiar centros poblados
                $centros.html('<option value="">Seleccione</option>').val('').trigger('change');
                
                // Si se seleccionó un distrito, cargar sus centros poblados
                if (distritoId) {
                    $.ajax({
                        type: 'GET',
                        url: "{{ path('ubigeo_centros_ajax', {'distritoId': 'ID'}) }}".replace('ID', distritoId),
                        success: function (data) {
                            for (let i = 0, total = data.length; i < total; i++) {
                                $centros.append('<option value="' + data[i].id + '">' + data[i].name + '</option>');
                            }
                        }
                    });
                }
            });

            // Interceptar clicks en enlaces de paginación
            $(document).on('click', '.pagination a', function(e){
                e.preventDefault();
                
                const url = $(this).attr('href');
                if (!url) return;
                
                // Mostrar indicador de carga
                $('#table-container').css('opacity', '0.5');
                
                // Realizar petición AJAX
                $.ajax({
                    type: 'GET',
                    url: url,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    success: function(response) {
                        // Actualizar la tabla con los nuevos resultados
                        $('#table-container').html(response).css('opacity', '1');
                        // Scroll al inicio de la tabla
                        $('html, body').animate({
                            scrollTop: $('#table-container').offset().top - 100
                        }, 300);
                    },
                    error: function(xhr, status, error) {
                        console.error('Error al cargar la página:', error);
                        $('#table-container').css('opacity', '1');
                    }
                });
            });
        });
        function actionForm(formid) {
            route = '{{ path('historialexcel_desaparecido_index') }}';
            document.getElementById(formid).action = route;
            document.getElementById(formid).submit();
            document.getElementById(formid).action = '';
        }
    </script>
{% endblock %}
