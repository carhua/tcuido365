{% block _javascripts %}
    <script src="https://cdn.amcharts.com/lib/5/index.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/percent.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/xy.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/themes/Kelly.js"></script>
    <script src="https://cdn.amcharts.com/lib/5/plugins/exporting.js"></script>
    <script src="{{ asset('js/amcharts.js') }}" type="text/javascript"></script>
    <script>

        let route;
        function filter(routeBase)
        {
            return route;
        }

        $(document).ready(function() {
            $('.m-select2').select2({
                placeholder: "Seleccione",
                allowClear: true
            });

            $(document).on('change', '#filter_size', function(){
                route = '{{ path('caso_violencia_index') }}';
                window.location = filter(route);
            });

            $(document).on('click', '.btn-send', function(e){
                e.preventDefault();
                
                // Obtener los datos del formulario
                const formData = $('#frm_filters').serialize();
                
                // Mostrar indicador de carga
                $('.btn-send').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Cargando...');
                
                // Realizar petición AJAX
                $.ajax({
                    type: 'GET',
                    url: '{{ path('grafico_violencia_index') }}',
                    data: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    success: function(response) {
                        if (response.success) {
                            // Actualizar gráficos con los nuevos datos
                            amChart.clusterColumn('chart_barra_anios', response.dataMeses.category, response.dataMeses.values, response.dataMeses.series, "Casos reportados", "Casos Reportados por Meses");
                            amChart.simpleColumn('chart_barra_meses', response.dataAnios.categoryX, response.dataAnios.valueY, response.dataAnios.values, "Casos Reportados por Año");
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error al cargar los datos:', error);
                        alert('Error al cargar los datos del gráfico');
                    },
                    complete: function() {
                        // Restaurar botón
                        $('.btn-send').prop('disabled', false).html('<i class="fas fa-search"></i> Buscar');
                    }
                });
            });

            $(document).on('click', '.btn-clear', function(){
                window.location.href = '{{ path('grafico_violencia_index') }}';
            });


            $("#select_provincias").change(function () {
                const provinciaId = $(this).val();
                const $distritos = $('#select_distritos');
                const $centros = $('#select_centros');
                
                // Limpiar distritos y centros poblados
                $distritos.html('<option value="">Seleccione</option>').val('').trigger('change');
                $centros.html('<option value="">Seleccione</option>').val('').trigger('change');
                
                // Si se seleccionó una provincia, cargar sus distritos
                if (provinciaId) {
                    $.ajax({
                        type: 'POST',
                        url: "{{ path('distrito_ajax') }}",
                        data: { provincia_id: provinciaId },
                        success: function (data) {
                            for (let i = 0, total = data.length; i < total; i++) {
                                $distritos.append('<option value="' + data[i].id + '">' + data[i].name + '</option>');
                            }
                        }
                    });
                }
            });

            $("#select_distritos").change(function () {
                const distritoId = $(this).val();
                const $centros = $('#select_centros');
                
                // Limpiar centros poblados
                $centros.html('<option value="">Seleccione</option>').val('').trigger('change');
                
                // Si se seleccionó un distrito, cargar sus centros poblados
                if (distritoId) {
                    $.ajax({
                        type: 'POST',
                        url: "{{ path('centros_ajax') }}",
                        data: { distrito_id: distritoId },
                        success: function (data) {
                            for (let i = 0, total = data.length; i < total; i++) {
                                $centros.append('<option value="' + data[i].id + '">' + data[i].name + '</option>');
                            }
                        }
                    });
                }
            });

            let data = {{ dataMeses | json_encode |raw }};
            amChart.clusterColumn('chart_barra_anios', data.category, data.values, data.series, "Casos reportados", "Casos Reportados por Meses");
            let dataAnios = {{ dataAnios | json_encode |raw }};
            amChart.simpleColumn('chart_barra_meses', dataAnios.categoryX, dataAnios.valueY, dataAnios.values, "Casos Reportados por Año");
        });
    </script>
{% endblock %}
